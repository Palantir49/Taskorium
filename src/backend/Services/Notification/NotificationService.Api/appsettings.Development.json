{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenTelemetry": {
    "UseOTLP": true,
    "ServiceName": "NotificationService",
    "UseMetricsExporter": "OTLP",
    "Endpoint": "http://localhost:4317"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Properties": {
      "Application": "NotificationService"
    }
  },
  "MessageBus": {
    "RabbitMq": {
      "Connection": {
        "HostName": "rabbit.taskorium.ru",
        "Port": 5671,
        "VirtualHost": "Taskorium",
        "ClientProvidedName": "notification-service:consumer",
        "AutomaticRecoveryEnabled": true,
        "TopologyRecoveryEnabled": true,
        "ConsumerDispatchConcurrency": 1,
        "UseSsl": true
      },
      "Publish": {},
      "Subscriptions": {
        "notification-received": {
          "Exchange": "notification.events",
          "ExchangeType": "topic",
          "Queue": "notification-received",
          "RoutingKey": "notification.received",
          "Durable": true,
          "Exclusive": false,
          "AutoDelete": false,
          "PrefetchCount": 10,
          "EnableDeadLetter": true,
          "DeadLetterExchange": "notification.events.dlx",
          "DeadLetterQueue": "notification-received.dlq",
          "DeadLetterRoutingKey": "notification-received.dlq",
          "EnableRetry": true,
          "RetryExchange": "notification.events.retry.exchange",
          "RetryQueue": "notification-received.retry",
          "RetryRoutingKey": "notification-received.retry",
          "RetryTtlMilliseconds": 30000,
          "MaxRetryCount": 3
        }
      }
    }
  },
  "Smtp": {
    "Host": "mail.taskorium.ru",
    "Port": 587,
    "UseStartTls": true,
    "FromName": "Система управления задачами Taskorium",
    "AcceptAnyCertificate": true
  },
  "Persistence": {
    "MongoDb": {
      "Host": "mongo.taskorium.ru",
      "Port": 27018,
      "DatabaseName": "NotificationDb"
    }
  }
}
