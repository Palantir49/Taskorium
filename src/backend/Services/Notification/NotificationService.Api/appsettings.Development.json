{
  "Logging": {
    "LogLevel": {
      "Default": "Trace",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenTelemetry": {
    "UseOTLP": true,
    "ServiceName": "NotificationServiceTest",
    "UseMetricsExporter": "OTLP",
    "Endpoint": "http://localhost:4317"
  },
  "MessageBus": {
    "RabbitMq": {
      "Connection": {
        "HostName": "rabbit.taskorium.ru",
        "Port": 5671,
        "VirtualHost": "Taskorium",
        "ClientProvidedName": "notification-service-test:consumer",
        "AutomaticRecoveryEnabled": true,
        "TopologyRecoveryEnabled": true,
        "ConsumerDispatchConcurrency": 1,
        "UseSsl": true
      },
      "Publish": {},
      "Subscriptions": {
        "notification-received": {
          "Exchange": "notification.events.test",
          "ExchangeType": "topic",
          "Queue": "notification-received-test",
          "RoutingKey": "notification.received.test",
          "Durable": true,
          "Exclusive": false,
          "AutoDelete": false,
          "PrefetchCount": 10,
          "EnableDeadLetter": true,
          "DeadLetterExchange": "notification.events.test.dlx",
          "DeadLetterQueue": "notification-received.test.dlq",
          "DeadLetterRoutingKey": "notification-received.test.dlq",
          "EnableRetry": true,
          "RetryExchange": "notification.events.test.retry.exchange",
          "RetryQueue": "notification-received-test.retry",
          "RetryRoutingKey": "notification-received-test.retry",
          "RetryTtlMilliseconds": 30000,
          "MaxRetryCount": 3
        }
      }
    }
  },
  "Smtp": {
    "Host": "mail.taskorium.ru",
    "Port": 587,
    "UseStartTls": true,
    "FromName": "Система управления задачами Taskorium",
    "AcceptAnyCertificate": true
  },
  "Persistence": {
    "MongoDb": {
      "Host": "mongo.taskorium.ru",
      "Port": 27018,
      "DatabaseName": "NotificationDbTest",
      "ReplicaSet": "rs0"
    }
  },
  "Outbox": {
    "PollingInterval": "00:00:05",
    "BatchSize": 50,
    "MaxRetries": 5
  }
}
