{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenTelemetry": {
    "UseOTLP": true,
    "ServiceName": "TaskService",
    "UseMetricsExporter": "OTLP",
    "Endpoint": "http://localhost:4317"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Properties": {
      "Application": "TaskService"
    }
  },
  "Services": {
    "FileStorageService": "http://localhost:5180"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5050"
      }
    }
  },
  "MessageBus": {
    "RabbitMq": {
      "Connection": {
        "HostName": "rabbit.taskorium.ru",
        "Port": 5671,
        "VirtualHost": "Taskorium",
        "ClientProvidedName": "task-service:publisher",
        "AutomaticRecoveryEnabled": true,
        "TopologyRecoveryEnabled": true,
        "UseSsl": true
      },
      "Publish": {
        "NotificationCreatedIntegrationEvent": {
          "Exchange": "notification.events",
          "ExchangeType": "topic",
          "RoutingKey": "notification.received"
        }
      }
    }
  }
}
