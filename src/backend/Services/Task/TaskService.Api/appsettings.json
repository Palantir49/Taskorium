{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenTelemetry": {
    "UseOTLP": true,
    "UseMetricsExporter": "OTLP",
    "Endpoint": "http://localhost:4317",
    "ServiceName": "TaskServiceTest"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Properties": {
      "Application": "TaskService"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost*",
      "https://localhost*"
    ]
  },
  "AllowedHosts": "*"
}
