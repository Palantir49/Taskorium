{
  "Logging": {
    "LogLevel": {
      "Default": "Trace",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MinIO": {
    "Endpoint": "storage.taskorium.ru:9000",
    "UseSSL": true,
    "DefaultBucket": "taskorium"
  },
  "OpenTelemetry": {
    "UseOTLP": true,
    "ServiceName": "FileStorageServiceTest",
    "UseMetricsExporter": "OTLP",
    "Endpoint": "http://localhost:4317"
  },
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  }
}
