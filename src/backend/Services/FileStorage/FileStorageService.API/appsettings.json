{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MinIO": {
    "Endpoint": "storage.taskorium.ru:9000",
    "UseSSL": true,
    "DefaultBucket": "taskorium"
  },
  "FileStorage": {
    "MaxFileSizeMB": 100,
    "AllowedExtensions": [
      ".jpg",
      ".png",
      ".pdf",
      ".docx",
      ".xlsx",
      ".txt"
    ],
    "PresignedUrlExpiryMinutes": 60
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Properties": {
      "Application": "FileStorageService"
    }
  }
}
