{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=filestorage;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "MinIO": {
    "Endpoint": "storage.taskorium.ru:9000",
    "AccessKey": "vEC7O4TehbryjIAqawg5",
    "SecretKey": "Tdy5BajZ0sfcJQIK2gx4vRuoMDF9Cn3AhqHLp8Xm",
    "UseSSL": true,
    "DefaultBucket": "taskorium"
